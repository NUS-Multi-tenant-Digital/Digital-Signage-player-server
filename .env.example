# Player Application Server 环境变量（Spring Boot）
# 复制为 .env 后按环境修改。生产环境请通过部署平台的密钥管理注入敏感项。

# ---- 服务端口 ----
SERVER_PORT=3000

# ---- MySQL ----
# 生产示例：jdbc:mysql://rm-xxxx.mysql.rds.aliyuncs.com:3306/digital_signage?useSSL=true&serverTimezone=Asia/Shanghai
DB_URL=jdbc:mysql://127.0.0.1:3306/digital_signage?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Shanghai
DB_USERNAME=root
DB_PASSWORD=

# ---- Redis ----
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# 阿里云 Redis 一般需要密码
REDIS_PASSWORD=

# ---- CORS（前端域名，逗号分隔）----
# 生产必须改成真实前端地址，例如：https://signage.example.com
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---- 阿里云 OSS / CDN ----
ALIYUN_OSS_ENDPOINT=https://oss-ap-southeast-1.aliyuncs.com
ALIYUN_OSS_BUCKET=digital-signage-media
ALIYUN_OSS_REGION=ap-southeast-1
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=

# 媒体公开访问地址（CDN 域名）
STORAGE_PUBLIC_BASE_URL=https://media.digital-signage.ltd
